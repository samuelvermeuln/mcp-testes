[server]
name = "gosystem-test-mcp"
transport = "stdio"

[project]
# Opcional: se definido, as tools podem ser chamadas sem passar project_root
project_root = "C:/Users/samuelv/RiderProjects/gosystem-mobility-api"

[context]
# project_local | isolated
mode = "isolated"

# Pasta raiz onde os contextos ficam armazenados (um diretorio por contexto)
store_root = "C:/Users/samuelv/.gosystem-test-mcp/contexts"

# Identidade do desenvolvedor e da janela/workspace
# Pode ser sobrescrito por argumento das tools ou por variavel de ambiente
developer_id = "samuel"
workspace_id = "vscode-window-01"

# Opcional: define contexto fixo manualmente
# context_id = "mobility-api-window-01"
